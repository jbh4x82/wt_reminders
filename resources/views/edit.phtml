    <script>
    (function () {
        var root = document.getElementById('wt-reminder-follow');
        if (!root) {
            return;
        }

        var searchUrl  = root.dataset.searchUrl;
        var actionUrl  = root.dataset.actionUrl;
        var csrf       = root.dataset.csrf;
        var searchBox  = document.getElementById('wt-reminder-search');
        var resultsEl  = document.getElementById('wt-reminder-results');
        var followList = document.getElementById('wt-reminder-following');

        var T = {
            follow:    <?= json_encode(I18N::translate('Follow')) ?>,
            following: <?= json_encode(I18N::translate('Following')) ?>,
            remove:    <?= json_encode(I18N::translate('Remove')) ?>,
            empty:     <?= json_encode(I18N::translate('You are not following anyone yet.')) ?>,
            none:      <?= json_encode(I18N::translate('No matches found.')) ?>
        };

        function esc(s) {
            var d = document.createElement('div');
            d.textContent = s == null ? '' : s;
            return d.innerHTML;
        }

        function clearResults() {
            resultsEl.innerHTML = '';
        }

        // POST a follow/unfollow and re-render the "following" list from the
        // server's authoritative response.
        function mutate(action, xref) {
            var body = 'action=' + encodeURIComponent(action)
                     + '&target=' + encodeURIComponent(xref)
                     + '&ajax=1';

            return fetch(actionUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-CSRF-TOKEN': csrf,
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: body,
                credentials: 'same-origin'
            }).then(function (r) { return r.json(); }).then(function (data) {
                if (data && data.following) {
                    renderFollowing(data.following);
                }
                return data;
            });
        }

        function renderFollowing(list) {
            followList.innerHTML = '';

            if (!list || list.length === 0) {
                var li = document.createElement('li');
                li.className = 'list-group-item text-muted';
                li.dataset.empty = '1';
                li.textContent = T.empty;
                followList.appendChild(li);
                return;
            }

            list.forEach(function (p) {
                var li = document.createElement('li');
                li.className = 'list-group-item d-flex justify-content-between align-items-center';
                li.dataset.xref = p.xref;

                var span = '<a href="' + esc(p.url) + '">' + esc(p.name) + '</a>';
                if (p.lifespan) {
                    span += ' <small class="text-muted ms-1">' + esc(p.lifespan) + '</small>';
                }
                if (p.birthday) {
                    span += '<br><small class="text-muted">' + esc(p.birthday) + '</small>';
                }

                li.innerHTML = '<span>' + span + '</span>'
                    + '<button type="button" class="btn btn-sm btn-outline-danger wt-reminder-remove" data-xref="'
                    + esc(p.xref) + '">' + esc(T.remove) + '</button>';
                followList.appendChild(li);
            });
        }

        function renderResults(results) {
            resultsEl.innerHTML = '';

            if (!results || results.length === 0) {
                var li = document.createElement('li');
                li.className = 'list-group-item text-muted';
                li.textContent = T.none;
                resultsEl.appendChild(li);
                return;
            }

            results.forEach(function (p) {
                var li = document.createElement('li');
                li.className = 'list-group-item d-flex justify-content-between align-items-center';

                var span = esc(p.name);
                if (p.lifespan) {
                    span += ' <small class="text-muted ms-1">' + esc(p.lifespan) + '</small>';
                }
                if (p.birthday) {
                    span += '<br><small class="text-muted">' + esc(p.birthday) + '</small>';
                }

                var btn;
                if (p.following) {
                    btn = '<span class="badge bg-success">&#9733; ' + esc(T.following) + '</span>';
                } else {
                    btn = '<button type="button" class="btn btn-sm btn-outline-primary wt-reminder-add" data-xref="'
                        + esc(p.xref) + '">' + esc(T.follow) + '</button>';
                }

                li.innerHTML = '<span>' + span + '</span>' + btn;
                resultsEl.appendChild(li);
            });
        }

        var timer = null;
        searchBox.addEventListener('input', function () {
            var q = searchBox.value.trim();
            if (timer) {
                clearTimeout(timer);
            }
            if (q.length < 2) {
                clearResults();
                return;
            }
            timer = setTimeout(function () {
                fetch(searchUrl + '&q=' + encodeURIComponent(q), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                }).then(function (r) { return r.json(); }).then(function (data) {
                    renderResults(data && data.results ? data.results : []);
                }).catch(clearResults);
            }, 250);
        });

        // Follow from a search result: mark it followed in place, refresh list.
        resultsEl.addEventListener('click', function (ev) {
            var btn = ev.target.closest('.wt-reminder-add');
            if (!btn) {
                return;
            }
            var xref = btn.dataset.xref;
            btn.disabled = true;
            mutate('follow', xref).then(function () {
                var badge = document.createElement('span');
                badge.className = 'badge bg-success';
                badge.innerHTML = '&#9733; ' + esc(T.following);
                btn.replaceWith(badge);
            });
        });

        // Remove from the following list.
        followList.addEventListener('click', function (ev) {
            var btn = ev.target.closest('.wt-reminder-remove');
            if (!btn) {
                return;
            }
            btn.disabled = true;
            mutate('unfollow', btn.dataset.xref);
        });

        // Hide the dropdown when clicking away.
        document.addEventListener('click', function (ev) {
            if (!root.contains(ev.target)) {
                clearResults();
            }
        });
    })();
    </script>
<?php endif ?>
