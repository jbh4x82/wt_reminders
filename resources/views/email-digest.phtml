<?php

declare(strict_types=1);

use Fisharebest\Webtrees\Fact;
use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Individual;
use Fisharebest\Webtrees\Module\ReminderService;
use Fisharebest\Webtrees\Module\RemindersModule;
use Fisharebest\Webtrees\Tree;

/**
 * Email body for a birthday-reminder digest.
 *
 * Localised to the subscriber's language: the cron sets I18N::init() and
 * Carbon::setLocale() per subscriber before rendering, so I18N::translate()
 * strings, relationship labels and dates all follow the recipient's language.
 *
 * @var Tree  $tree
 * @var array<int,array{title:string,is_today:bool,events:array<int,array{record:Individual,fact:Fact,distance:int,relationship:string}>}> $sections
 * @var int   $days_ahead
 * @var int   $max_distance
 * @var bool  $include_deceased
 * @var array<string,string> $user_emails  xref => linked account email (for the "Send birthday email" link)
 */

$manage_url = route(RemindersModule::class, ['tree' => $tree->name()]);
?>
<div style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #222;">
    <?php foreach ($sections as $section) : ?>
        <h2 style="font-size: 18px; margin: 18px 0 8px;"><?= e($section['title']) ?></h2>

        <?php foreach ($section['events'] as $event) : ?>
            <?php
            $record   = $event['record'];
            $fact     = $event['fact'];
            $anniv    = (int) $fact->anniv;
            $deceased = !empty($event['deceased']);
            ?>
            <div style="margin: 0 0 12px;">
                <a href="<?= e($record->url()) ?>" style="color: #045704; text-decoration: none; font-weight: bold;">
                    <?= e(ReminderService::displayName($record)) ?>
                </a>
                <?php if (!empty($event['followed'])) : ?>
                    <span style="display: inline-block; margin-left: 6px; padding: 1px 7px; font-size: 11px; font-weight: bold; color: #045704; background: #e7f3e7; border-radius: 10px; vertical-align: middle;">&#9733; <?= e(I18N::translate('Followed')) ?></span>
                <?php endif ?>
                <?php if ($deceased) : ?>
                    <span style="margin-left: 4px; color: #888;" title="<?= e(I18N::translate('Deceased')) ?>">&#10013;</span>
                <?php endif ?>
                <div style="margin-left: 16px; color: #444;">
                    <?= e(strip_tags($fact->date()->display($tree, null, true))) ?>
                    <?php if ($anniv > 0) : ?>
                        (<?= $anniv ?> <?= e($anniv === 1 ? I18N::translate('year') : I18N::translate('years')) ?>)
                    <?php endif ?>
                    <?php if ($event['relationship'] !== '') : ?>
                        <?php // Trusted webtrees-generated label: may contain markup (e.g. ordinal <sup>, → arrows) in some languages, so render as HTML rather than e()-escaping it (which would show the literal tags). ?>
                        <br><span style="color: #045704;"><?= $event['relationship'] ?></span>
                    <?php endif ?>
                    <?php $bday_email = $user_emails[$record->xref()] ?? null; ?>
                    <?php if ($section['is_today'] && $bday_email !== null && !$deceased) : ?>
                        <br><a href="mailto:<?= e($bday_email) ?>?subject=<?= rawurlencode(I18N::translate('Happy birthday')) ?>" style="color: #045704; text-decoration: none;">&#9993; <?= e(I18N::translate('Send birthday email')) ?></a>
                    <?php endif ?>
                </div>
            </div>
        <?php endforeach ?>
    <?php endforeach ?>

    <hr style="margin: 20px 0; border: none; border-top: 1px solid #ccc;">
    <p style="font-size: 12px; color: #666;">
        <u><?= e(I18N::translate('Your current settings')) ?></u><br>
        <?= e(I18N::translate('Maximum distance to relative')) ?>: <?= $max_distance === 0 ? e(I18N::translate('Unlimited')) : (int) $max_distance ?><br>
        <?= e($days_ahead === 1
            ? I18N::translate('Notifications: %s day ahead', I18N::number($days_ahead))
            : I18N::translate('Notifications: %s days ahead', I18N::number($days_ahead))) ?>
        <?php if (!empty($include_deceased)) : ?>
            <br><?= e(I18N::translate('Including birthdays of deceased people')) ?>
        <?php endif ?>
    </p>
    <p style="font-size: 12px;">
        <a href="<?= e($manage_url) ?>"><?= e(I18N::translate('Manage your birthday reminder subscriptions')) ?></a>
    </p>
</div>
